@page "/cheques"
@rendermode InteractiveServer
@inject ICheckRepository CheckRepository
@inject IUserAuthenticationRepository UserAuthenticationRepository
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Fidelis Cheques</PageTitle>

<div class="screen-header">
    <div>
        <p class="eyebrow">Modulo</p>
        <h1>Cheques</h1>
    </div>
    <div class="quick-actions">
        <button class="btn btn-primary" @onclick="NewCheck">Nuevo cheque</button>
        <button class="btn btn-outline-secondary" @onclick="LoadAsync" disabled="@isLoading">Actualizar</button>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="alert @statusCss" role="alert">@statusMessage</div>
}

@if (isLoading)
{
    <div class="status-panel">Cargando cheques...</div>
}
else
{
    <section class="check-workspace">
        <aside class="check-list-panel">
            @if (ChecksToPrint.Count > 0)
            {
                <div class="checks-to-print-card">
                    <div class="panel-heading compact">
                        <div>
                            <h2>Cheques para imprimir</h2>
                            <span>@ChecksToPrint.Count pendiente(s)</span>
                        </div>
                    </div>
                    <div class="income-list compact-list">
                        @foreach (var check in ChecksToPrint)
                        {
                            <button class="income-row @(selectedId == check.Id ? "selected" : "")" @onclick="() => EditCheck(check)">
                                <span class="row-main">
                                    <strong>@check.Payee</strong>
                                    <small>#@check.CheckNumber • @check.AccountName</small>
                                </span>
                                <span class="row-side">
                                    <strong>@Money(check.Amount)</strong>
                                    <small>@check.CheckDate.ToString("MM/dd/yyyy")</small>
                                </span>
                            </button>
                        }
                    </div>
                </div>
            }

            <div class="panel-heading">
                <div>
                    <h2>Cheques recientes</h2>
                    <span>@filteredChecks.Count cheque(s)</span>
                </div>
            </div>

            <div class="income-filter">
                <input class="form-control" placeholder="Buscar beneficiario, cuenta, numero..." @bind="searchText" @bind:event="oninput" />
                <div class="segmented-filter check-filter" role="group" aria-label="Filtrar cheques">
                    <button class="@StatusButtonClass("active")" type="button" @onclick='() => statusFilter = "active"'>Activos</button>
                    <button class="@StatusButtonClass("draft")" type="button" @onclick='() => statusFilter = "draft"'>Borrador</button>
                    <button class="@StatusButtonClass("printed")" type="button" @onclick='() => statusFilter = "printed"'>Impresos</button>
                    <button class="@StatusButtonClass("all")" type="button" @onclick='() => statusFilter = "all"'>Todos</button>
                </div>
            </div>

            <div class="income-list">
                @foreach (var check in filteredChecks)
                {
                    <button class="income-row @(selectedId == check.Id ? "selected" : "")" @onclick="() => EditCheck(check)">
                        <span class="row-main">
                            <strong>@check.Payee</strong>
                            <small>#@check.CheckNumber • @check.AccountName</small>
                        </span>
                        <span class="row-side">
                            <strong>@Money(check.Amount)</strong>
                            <small>@check.CheckDate.ToString("MM/dd/yyyy")</small>
                        </span>
                        <span class="row-badges">
                            <span class="@BadgeClass(check.Status)">@check.Status</span>
                        </span>
                    </button>
                }
            </div>
        </aside>

        <section class="receipt-panel">
            <EditForm Model="entry" OnValidSubmit="SaveAsync">
                <DataAnnotationsValidator />

                <div class="receipt-topline">
                    <div>
                        <p class="eyebrow">@FormModeLabel</p>
                        <h2>@(entry.Id > 0 ? $"Cheque #{entry.CheckNumber}" : "Nuevo cheque")</h2>
                    </div>
                    <div class="receipt-amount">
                        <span>Total</span>
                        <strong>@Money(entry.Amount)</strong>
                    </div>
                </div>

                <div class="receipt-grid">
                    <div class="field span-2">
                        <label>Egreso pendiente de cheque</label>
                        <select class="form-select" value="@entry.ExpenseId" @onchange="OnExpenseChanged" disabled="@(!CanEditForm)">
                            <option value="">Preparar cheque manual</option>
                            @foreach (var expense in lookups.PendingExpenses)
                            {
                                <option value="@expense.Id">@FormatExpenseOption(expense)</option>
                            }
                        </select>
                    </div>

                    <div class="field">
                        <label>Cuenta bancaria</label>
                        <InputSelect class="form-select" @bind-Value="entry.AccountId" disabled="@(!CanEditForm)">
                            <option value="0">Seleccionar</option>
                            @foreach (var account in lookups.Accounts)
                            {
                                <option value="@account.Id">@account.Name</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="() => entry.AccountId" />
                    </div>

                    <div class="field">
                        <label>Numero de cheque</label>
                        <InputText class="form-control" @bind-Value="entry.CheckNumber" disabled="@(!CanEditForm)" />
                        <ValidationMessage For="() => entry.CheckNumber" />
                    </div>

                    <div class="field">
                        <label>Fecha</label>
                        <InputDate class="form-control" @bind-Value="entry.CheckDate" disabled="@(!CanEditForm)" />
                        <ValidationMessage For="() => entry.CheckDate" />
                    </div>

                    <div class="field amount-field">
                        <label>Monto</label>
                        <InputNumber class="form-control" @bind-Value="entry.Amount" disabled="@(!CanEditForm)" />
                        <ValidationMessage For="() => entry.Amount" />
                    </div>

                    <div class="field span-2">
                        <label>Beneficiario</label>
                        <InputText class="form-control" @bind-Value="entry.Payee" disabled="@(!CanEditForm)" />
                        <ValidationMessage For="() => entry.Payee" />
                    </div>

                    <div class="field span-2">
                        <label>Direccion del beneficiario</label>
                        <InputTextArea class="form-control" @bind-Value="entry.PayeeAddress" rows="2" disabled="@(!CanEditForm)" />
                        <ValidationMessage For="() => entry.PayeeAddress" />
                    </div>

                    <div class="field span-2">
                        <label>Memo / detalle del voucher</label>
                        <InputTextArea class="form-control" @bind-Value="entry.Memo" rows="3" disabled="@(!CanEditForm)" />
                        <ValidationMessage For="() => entry.Memo" />
                    </div>
                </div>

                <div class="deposit-hint route">
                    <strong>Voucher.</strong>
                    <span>Selecciona un egreso registrado para crear el voucher sin duplicar el gasto.</span>
                </div>

                @if (lookups.PendingExpenses.Count == 0 && entry.Id <= 0)
                {
                    <div class="deposit-hint locked">
                        <strong>No hay egresos pendientes.</strong>
                        <span>Registra primero el egreso con método Cheque y luego prepara el voucher aquí.</span>
                    </div>
                }

                @if (selectedCheck is not null && !CanEditForm)
                {
                    <div class="deposit-hint locked">
                        <strong>Solo lectura.</strong>
                        <span>Los cheques impresos o anulados no se editan; se anulan y se crea uno nuevo si hace falta.</span>
                    </div>
                }

                <div class="check-preview-mini" aria-label="Vista del cheque">
                    <div class="mini-check-line top">
                        <span>@entry.CheckDate.ToString("MM/dd/yyyy")</span>
                        <strong>@Money(entry.Amount)</strong>
                    </div>
                    <div class="mini-payee">@entry.Payee</div>
                    <div class="mini-words">@AmountInWords</div>
                    <div class="mini-memo">@entry.Memo</div>
                </div>

                <div class="form-actions">
                    <button class="btn btn-primary" type="submit" disabled="@(isSaving || !CanEditForm)">
                        @(isSaving ? "Guardando..." : "Guardar borrador")
                    </button>

                    @if (selectedCheck is not null)
                    {
                        <a class="btn btn-outline-secondary" href="@PrintUrl" target="_blank">Vista imprimible</a>
                        @if (selectedCheck.Status != "Anulado")
                        {
                            <button class="btn btn-outline-secondary" type="button" @onclick="MarkPrintedAsync">Marcar impreso</button>
                            <button class="btn btn-outline-danger" type="button" @onclick="AskVoid">Anular</button>
                        }
                    }

                    <button class="btn btn-outline-secondary" type="button" @onclick="NewCheck">Limpiar</button>
                </div>
            </EditForm>
        </section>
    </section>
}

@if (showVoidDialog)
{
    <div class="modal-backdrop-lite">
        <div class="void-dialog">
            <h2>Anular cheque #@entry.CheckNumber</h2>
            <p>Esta accion conserva el historial del cheque y libera el numero para auditoria visual.</p>
            <label>Motivo</label>
            <InputTextArea class="form-control" @bind-Value="voidReason" rows="3" />
            <div class="form-actions">
                <button class="btn btn-outline-secondary" @onclick="CancelVoid">Cancelar</button>
                <button class="btn btn-outline-danger" @onclick="VoidAsync">Anular cheque</button>
            </div>
        </div>
    </div>
}

@if (showExpenseApprovalDialog && pendingExpenseApproval is not null)
{
    <div class="modal-backdrop-lite">
        <div class="void-dialog">
            <h2>Aprobación requerida</h2>
            <p>Este egreso fue registrado previamente como cheque. Para prepararlo como cheque de oficina, otro usuario con permiso igual o mayor debe aprobar la corrección.</p>
            <div class="deposit-hint route">
                <strong>@pendingExpenseApproval.Description</strong>
                <span>@pendingExpenseApproval.AccountName • @Money(pendingExpenseApproval.Amount) • @pendingExpenseApproval.Date.ToString("MM/dd/yyyy")</span>
            </div>

            @if (!string.IsNullOrWhiteSpace(approvalMessage))
            {
                <div class="@approvalCss">@approvalMessage</div>
            }

            <label>Usuario aprobador</label>
            <input class="form-control" @bind="approvalUserName" disabled="@isApprovingExpense" />
            <label>Contraseña</label>
            <input class="form-control" type="password" @bind="approvalPassword" disabled="@isApprovingExpense" />

            <div class="form-actions">
                <button class="btn btn-outline-secondary" type="button" @onclick="CancelExpenseApproval" disabled="@isApprovingExpense">Cancelar</button>
                <button class="btn btn-primary" type="button" @onclick="ApproveExpenseSelectionAsync" disabled="@isApprovingExpense">
                    @(isApprovingExpense ? "Validando..." : "Aprobar y cargar egreso")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private CheckLookups lookups = new([], []);
    private IReadOnlyList<CheckVoucher> checks = [];
    private List<CheckVoucher> filteredChecks => FilterChecks().ToList();
    private List<CheckVoucher> ChecksToPrint => checks
        .Where(c => c.Status == "Borrador")
        .OrderBy(c => c.CheckDate)
        .ThenBy(c => c.CheckNumber)
        .ToList();
    private CheckEntry entry = new();
    private CheckVoucher? selectedCheck;
    private int? selectedId;
    private string searchText = string.Empty;
    private string statusFilter = "active";
    private string? statusMessage;
    private string statusCss = "alert-info";
    private string voidReason = string.Empty;
    private string approvalUserName = string.Empty;
    private string approvalPassword = string.Empty;
    private string? approvalMessage;
    private string approvalCss = "alert-info";
    private bool isLoading = true;
    private bool isSaving;
    private bool showVoidDialog;
    private bool showExpenseApprovalDialog;
    private bool isApprovingExpense;
    private CheckExpenseOption? pendingExpenseApproval;

    private string FormModeLabel => entry.Id > 0 ? "Editar cheque" : "Preparar cheque";
    private bool CanEditForm => entry.Id <= 0 || selectedCheck?.Status == "Borrador";
    private string PrintUrl => selectedCheck is null ? "#" : $"cheques/{selectedCheck.Id}/imprimir";
    private string AmountInWords => SpanishMoneyWriter.ToDollars(entry.Amount);

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        statusMessage = null;

        try
        {
            lookups = await CheckRepository.GetLookupsAsync();
            checks = await CheckRepository.GetRecentAsync();
            if (entry.AccountId <= 0)
            {
                entry.AccountId = lookups.Accounts.FirstOrDefault()?.Id ?? 0;
            }
        }
        catch (Exception ex)
        {
            SetStatus($"No se pudieron cargar cheques: {FriendlyDatabaseMessage(ex)}", "alert-danger");
        }
        finally
        {
            isLoading = false;
        }
    }

    private IEnumerable<CheckVoucher> FilterChecks()
    {
        var query = checks.AsEnumerable();
        query = statusFilter switch
        {
            "active" => query.Where(c => c.Status != "Anulado"),
            "draft" => query.Where(c => c.Status == "Borrador"),
            "printed" => query.Where(c => c.Status == "Impreso"),
            _ => query
        };

        if (!string.IsNullOrWhiteSpace(searchText))
        {
            var text = searchText.Trim();
            query = query.Where(c =>
                c.Payee.Contains(text, StringComparison.OrdinalIgnoreCase) ||
                c.CheckNumber.Contains(text, StringComparison.OrdinalIgnoreCase) ||
                c.AccountName.Contains(text, StringComparison.OrdinalIgnoreCase) ||
                (c.Memo?.Contains(text, StringComparison.OrdinalIgnoreCase) ?? false));
        }

        return query;
    }

    private void NewCheck()
    {
        entry = new CheckEntry
        {
            CheckDate = DateTime.Today,
            AccountId = lookups.Accounts.FirstOrDefault()?.Id ?? 0
        };
        selectedId = null;
        selectedCheck = null;
        statusMessage = null;
        voidReason = string.Empty;
    }

    private void EditCheck(CheckVoucher check)
    {
        selectedId = check.Id;
        selectedCheck = check;
        statusMessage = null;
        entry = new CheckEntry
        {
            Id = check.Id,
            ExpenseId = check.ExpenseId,
            AccountId = check.AccountId,
            CheckNumber = check.CheckNumber,
            CheckDate = check.CheckDate,
            Payee = check.Payee,
            PayeeAddress = check.PayeeAddress,
            Amount = check.Amount,
            Memo = check.Memo
        };
    }

    private void OnExpenseChanged(ChangeEventArgs args)
    {
        if (!int.TryParse(args.Value?.ToString(), out var expenseId))
        {
            entry.ExpenseId = null;
            return;
        }

        var expense = lookups.PendingExpenses.FirstOrDefault(e => e.Id == expenseId);
        if (expense is null)
        {
            return;
        }

        pendingExpenseApproval = expense;
        approvalUserName = string.Empty;
        approvalPassword = string.Empty;
        approvalMessage = null;
        showExpenseApprovalDialog = true;
    }

    private void ApplyApprovedExpense(CheckExpenseOption expense)
    {
        entry.ExpenseId = expense.Id;
        entry.AccountId = expense.AccountId;
        entry.CheckDate = expense.Date;
        entry.Payee = expense.Description;
        entry.Amount = expense.Amount;
        entry.CheckNumber = expense.CheckNumber ?? entry.CheckNumber;
        entry.Memo = expense.SubcategoryName;
        statusMessage = null;
    }

    private void CancelExpenseApproval()
    {
        showExpenseApprovalDialog = false;
        pendingExpenseApproval = null;
        approvalUserName = string.Empty;
        approvalPassword = string.Empty;
        approvalMessage = null;
        entry.ExpenseId = null;
    }

    private async Task ApproveExpenseSelectionAsync()
    {
        if (pendingExpenseApproval is null)
        {
            return;
        }

        isApprovingExpense = true;
        approvalMessage = null;

        try
        {
            if (string.IsNullOrWhiteSpace(approvalUserName) || string.IsNullOrWhiteSpace(approvalPassword))
            {
                SetApprovalStatus("Escribe usuario y contraseña del aprobador.", "alert alert-warning");
                return;
            }

            var currentState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var currentUser = currentState.User;
            var currentUserName = currentUser.Identity?.Name ?? string.Empty;
            var approver = await UserAuthenticationRepository.ValidateCredentialsAsync(approvalUserName, approvalPassword);
            if (approver is null)
            {
                SetApprovalStatus("Usuario o contraseña de aprobación inválidos.", "alert alert-danger");
                return;
            }

            if (approver.UserName.Equals(currentUserName, StringComparison.OrdinalIgnoreCase))
            {
                SetApprovalStatus("La aprobación debe hacerla otro usuario.", "alert alert-danger");
                return;
            }

            var currentRank = GetHighestRoleRank(currentUser.Claims
                .Where(c => c.Type == System.Security.Claims.ClaimTypes.Role)
                .Select(c => c.Value));
            var approverRank = GetHighestRoleRank(approver.Roles);

            if (approverRank < currentRank)
            {
                SetApprovalStatus("El aprobador debe tener permiso igual o mayor al usuario actual.", "alert alert-danger");
                return;
            }

            ApplyApprovedExpense(pendingExpenseApproval);
            showExpenseApprovalDialog = false;
            SetStatus($"Egreso aprobado por {approver.FullName} y cargado para preparar cheque.", "alert-success");
            pendingExpenseApproval = null;
            approvalUserName = string.Empty;
            approvalPassword = string.Empty;
        }
        finally
        {
            isApprovingExpense = false;
        }
    }

    private void SetApprovalStatus(string message, string css)
    {
        approvalMessage = message;
        approvalCss = css;
    }

    private static int GetHighestRoleRank(IEnumerable<string> roles) =>
        roles.Select(GetRoleRank).DefaultIfEmpty(0).Max();

    private static int GetRoleRank(string role)
    {
        var normalized = role.Trim().ToUpperInvariant();
        return normalized switch
        {
            "ADMINISTRADOR" or "ADMIN" => 100,
            "PASTOR" => 90,
            "FINANZAS" or "TESORERIA" or "TESORERÍA" or "TREASURER" => 80,
            "SUPERVISOR" => 70,
            "USUARIO" or "USER" => 10,
            _ => 0
        };
    }

    private async Task SaveAsync()
    {
        isSaving = true;

        try
        {
            var result = await CheckRepository.SaveDraftAsync(entry, await GetCurrentUserNameAsync());
            if (!result.Saved)
            {
                SetStatus(result.ErrorMessage ?? "No se pudo guardar el cheque.", "alert-danger");
                return;
            }

            SetStatus("Cheque guardado como borrador.", "alert-success");
            await LoadAsync();
            if (result.CheckId.HasValue)
            {
                var saved = checks.FirstOrDefault(c => c.Id == result.CheckId.Value);
                if (saved is not null)
                {
                    EditCheck(saved);
                }
            }
        }
        catch (Exception ex)
        {
            SetStatus($"No se pudo guardar el cheque: {FriendlyDatabaseMessage(ex)}", "alert-danger");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task MarkPrintedAsync()
    {
        if (selectedCheck is null)
        {
            return;
        }

        var result = await CheckRepository.MarkPrintedAsync(selectedCheck.Id, await GetCurrentUserNameAsync());
        SetStatus(result.Saved ? "Cheque marcado como impreso." : result.ErrorMessage ?? "No se pudo marcar como impreso.", result.Saved ? "alert-success" : "alert-danger");
        await LoadAsync();
    }

    private void AskVoid()
    {
        voidReason = string.Empty;
        showVoidDialog = true;
    }

    private void CancelVoid()
    {
        showVoidDialog = false;
        voidReason = string.Empty;
    }

    private async Task VoidAsync()
    {
        if (selectedCheck is null)
        {
            return;
        }

        var result = await CheckRepository.VoidAsync(selectedCheck.Id, voidReason, await GetCurrentUserNameAsync());
        showVoidDialog = false;
        SetStatus(result.Saved ? "Cheque anulado correctamente." : result.ErrorMessage ?? "No se pudo anular el cheque.", result.Saved ? "alert-success" : "alert-danger");
        await LoadAsync();
        NewCheck();
    }

    private async Task<string> GetCurrentUserNameAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        return authState.User.Identity?.Name ?? "CFS.Web";
    }

    private void SetStatus(string message, string css)
    {
        statusMessage = message;
        statusCss = css;
    }

    private string StatusButtonClass(string value) =>
        statusFilter == value ? "selected" : string.Empty;

    private static string BadgeClass(string status) => status switch
    {
        "Borrador" => "badge-soft warning",
        "Impreso" => "badge-soft success",
        "Anulado" => "badge-soft danger",
        _ => "badge-soft"
    };

    private static string FriendlyDatabaseMessage(Exception ex)
    {
        var message = ex.Message;
        return message.Contains("CFS_Cheques", StringComparison.OrdinalIgnoreCase)
            ? "Falta crear la tabla dbo.CFS_Cheques. Usa el script CFS.Data/Sql/CFS_Cheques.sql."
            : message;
    }

    private static string FormatExpenseOption(CheckExpenseOption expense) =>
        $"{expense.Date:MM/dd/yyyy} • {expense.Description} • {expense.Amount:C2} • {expense.AccountName}";

    private static string Money(decimal value) => value.ToString("C2");
}
