@page "/"
@layout LoginLayout
@rendermode InteractiveServer
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Authorization
@using CFS.Core.Models
@using CFS.Core.Services
@inject NavigationManager Navigation
@inject IStripeCheckoutService StripeCheckout
@inject ISignupRepository Signups
@inject ISalesLeadRepository SalesLeads
@inject ILogger<Home> Logger

<PageTitle>Fidelis Financial Management</PageTitle>

<main class="public-home">
    <header class="public-nav">
        <a class="public-brand" href="/">
            <img src="images/fidelis-logo.png" alt="Fidelis Financial Management" />
            <strong>Fidelis</strong>
        </a>
        <nav aria-label="Navegación pública">
            <a href="#features">Funciones</a>
            <a href="#pricing">Planes</a>
            <a class="public-login-link" href="login?returnUrl=%2Fdashboard">Ingresar</a>
        </nav>
    </header>

    <section class="public-hero">
        <div class="public-hero-copy">
            <p class="eyebrow">Fidelis Financial Management</p>
            <h1>Finanzas claras para iglesias que necesitan orden, reportes y confianza.</h1>
            <p>
                Fidelis Financial Management ayuda a registrar ingresos, depósitos, cheques, conciliaciones bancarias y reportes financieros en un solo sistema diseñado para tesorería de iglesia.
            </p>
            <div class="public-actions">
                <a class="btn btn-primary" href="#pricing">Ver planes</a>
                <a class="btn btn-outline-secondary" href="login?returnUrl=%2Fdashboard">Entrar al sistema</a>
            </div>
        </div>

        <aside class="public-snapshot" aria-label="Resumen de Fidelis Financial Management">
            <div>
                <span>Reportes</span>
                <strong>P&L por cuenta</strong>
            </div>
            <div>
                <span>Banco</span>
                <strong>Depósitos y conciliación</strong>
            </div>
            <div>
                <span>AI Advisor</span>
                <strong>Insights financieros</strong>
            </div>
        </aside>
    </section>

    <section class="public-section" id="features">
        <div class="public-section-heading">
            <p class="eyebrow">Qué incluye</p>
            <h2>Un sistema financiero hecho alrededor del flujo real de una iglesia.</h2>
        </div>

        <div class="public-feature-grid">
            <article>
                <strong>Ingresos y diezmos</strong>
                <p>Registra recibos, miembros, métodos de pago y fondos especiales sin mezclar cuentas bancarias.</p>
            </article>
            <article>
                <strong>Depósitos por cuenta</strong>
                <p>Agrupa efectivo y cheques para depositar, manteniendo cada cuenta bancaria separada.</p>
            </article>
            <article>
                <strong>Cheques tipo voucher</strong>
                <p>Prepara cheques con detalle para impresión y control interno de tesorería.</p>
            </article>
            <article>
                <strong>Conciliación bancaria</strong>
                <p>Compara el estado del banco con el saldo en libros de Fidelis y cierra periodos con control.</p>
            </article>
            <article>
                <strong>Reportes financieros</strong>
                <p>Profit and Loss, detail, balance sheet y reportes de diezmos listos para imprimir o guardar en PDF.</p>
            </article>
            <article>
                <strong>Asistente IA</strong>
                <p>Insights y preguntas financieras sobre el tenant como add-on o parte del plan avanzado.</p>
            </article>
        </div>
    </section>

    <section class="public-section pricing-section" id="pricing">
        <div class="public-section-heading">
            <p class="eyebrow">Suscripciones</p>
            <h2>Planes pensados para el nivel de operación de cada iglesia.</h2>
        </div>

        <div class="billing-toggle" role="group" aria-label="Ciclo de facturación">
            <button type="button" class="@(billingCycle == BillingCycle.Monthly ? "active" : "")" @onclick="() => SetBillingCycle(BillingCycle.Monthly)">
                Mensual
            </button>
            <button type="button" class="@(billingCycle == BillingCycle.Annual ? "active" : "")" @onclick="() => SetBillingCycle(BillingCycle.Annual)">
                Anual <span class="discount-pill">-10%</span>
            </button>
        </div>

        <div class="pricing-grid">
            @foreach (var plan in Plans)
            {
                <article class="pricing-card @(plan.Highlight ? "highlight" : "")">
                    @if (plan.Highlight)
                    {
                        <span class="plan-badge">Recomendado</span>
                    }
                    <h3>@plan.Name</h3>
                    <p>@plan.Description</p>
                    @if (plan.IsCustomPricing)
                    {
                        <div class="plan-price">
                            <strong>Custom</strong>
                        </div>
                    }
                    else
                    {
                        <div class="plan-price">
                            <strong>@FormatPrice(plan, billingCycle)</strong>
                            <span>@(billingCycle == BillingCycle.Monthly ? "/mes" : "/año")</span>
                        </div>
                        @if (billingCycle == BillingCycle.Annual)
                        {
                            <p class="plan-savings">Ahorras @FormatSavings(plan)/año pagando anual</p>
                        }
                    }
                    <ul>
                        @foreach (var feature in plan.Features)
                        {
                            <li>@feature</li>
                        }
                    </ul>
                    @if (plan.IsCustomPricing)
                    {
                        <button type="button" class="btn btn-outline-secondary" @onclick="OpenLeadWizard">
                            Contactar ventas
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn @(plan.Highlight ? "btn-primary" : "btn-outline-secondary")" @onclick="() => OpenCheckout(plan)">
                            Escoger plan
                        </button>
                    }
                </article>
            }
        </div>

        <div class="founder-note">
            <strong>Iglesia fundadora</strong>
            <span>Tu congregación mantiene acceso completo sin costo como cuenta fundadora de Fidelis.</span>
        </div>
    </section>

    @if (selectedPlan is not null)
    {
        <div class="checkout-overlay" role="dialog" aria-modal="true" aria-label="Escoger plan">
            <div class="checkout-modal">
                <button type="button" class="checkout-close" aria-label="Cerrar" @onclick="CloseCheckout">×</button>

                <ol class="checkout-steps">
                    <li class="@(checkoutStep >= 1 ? "done" : "")"><span class="step-index">1</span> Escoger plan</li>
                    <li class="@(checkoutStep >= 2 ? "done" : "")"><span class="step-index">2</span> Crear cuenta</li>
                    <li class="@(checkoutStep >= 3 ? "done" : "")"><span class="step-index">3</span> Pago</li>
                </ol>

                <div class="checkout-body">
                    <div class="checkout-main">
                        @if (checkoutStep == 1)
                        {
                            <h3>Confirma tu plan</h3>
                            <p>Puedes cambiar de plan antes de continuar.</p>
                            <div class="checkout-plan-options">
                                @foreach (var plan in Plans.Where(p => !p.IsCustomPricing))
                                {
                                    <label class="checkout-plan-option @(selectedPlan == plan ? "selected" : "")">
                                        <input type="radio" name="checkout-plan" checked="@(selectedPlan == plan)" @onchange="() => selectedPlan = plan" />
                                        <span>@plan.Name — @FormatPrice(plan, billingCycle)@(billingCycle == BillingCycle.Monthly ? "/mes" : "/año")</span>
                                    </label>
                                }
                            </div>
                            <button type="button" class="btn btn-primary" @onclick="() => checkoutStep = 2">Continuar</button>
                        }
                        else if (checkoutStep == 2)
                        {
                            <h3>Crea tu cuenta</h3>
                            <EditForm Model="account" OnValidSubmit="() => checkoutStep = 3">
                                <DataAnnotationsValidator />
                                <div class="checkout-field">
                                    <label>Nombre de la iglesia / organización</label>
                                    <InputText @bind-Value="account.OrganizationName" />
                                </div>
                                <div class="checkout-field">
                                    <label>Correo electrónico</label>
                                    <InputText @bind-Value="account.Email" type="email" />
                                </div>
                                <div class="checkout-field">
                                    <label>Contraseña</label>
                                    <InputText @bind-Value="account.Password" type="password" />
                                </div>
                                <div class="checkout-field">
                                    <label>Teléfono</label>
                                    <InputText @bind-Value="account.Phone" />
                                </div>
                                <button type="button" class="btn btn-outline-secondary" @onclick="() => checkoutStep = 1">Atrás</button>
                                <button type="submit" class="btn btn-primary">Continuar a pago</button>
                            </EditForm>
                        }
                        else
                        {
                            <h3>Pago</h3>
                            <p class="checkout-pending">
                                Serás redirigido a Stripe para completar tu pago de forma segura.
                            </p>
                            @if (checkoutError is not null)
                            {
                                <p class="checkout-error">@checkoutError</p>
                            }
                            <button type="button" class="btn btn-outline-secondary" @onclick="() => checkoutStep = 2" disabled="@isRedirectingToStripe">Atrás</button>
                            <button type="button" class="btn btn-primary" @onclick="StartStripeCheckoutAsync" disabled="@isRedirectingToStripe">
                                @(isRedirectingToStripe ? "Redirigiendo..." : "Pagar con Stripe")
                            </button>
                        }
                    </div>

                    <aside class="checkout-summary">
                        <h4>Tu plan</h4>
                        @if (billingCycle == BillingCycle.Annual)
                        {
                            <p class="checkout-savings">Ahorras @FormatSavings(selectedPlan)/año 🎉</p>
                        }
                        <div class="checkout-summary-row">
                            <span>@selectedPlan.Name</span>
                            <strong>@FormatPrice(selectedPlan, billingCycle)@(billingCycle == BillingCycle.Monthly ? "/mes" : "/año")</strong>
                        </div>
                        <hr />
                        <div class="checkout-summary-row checkout-total">
                            <span>Total</span>
                            <strong>@FormatPrice(selectedPlan, billingCycle)@(billingCycle == BillingCycle.Monthly ? "/mes" : "/año")</strong>
                        </div>
                        <p class="checkout-fineprint">Impuestos no incluidos. Cancela cuando quieras.</p>
                    </aside>
                </div>
            </div>
        </div>
    }

    @if (showLeadWizard)
    {
        <div class="checkout-overlay" role="dialog" aria-modal="true" aria-label="Contactar ventas">
            <div class="checkout-modal">
                <button type="button" class="checkout-close" aria-label="Cerrar" @onclick="CloseLeadWizard">×</button>

                <ol class="checkout-steps">
                    <li class="@(leadStep >= 1 ? "done" : "")"><span class="step-index">1</span> Tus datos</li>
                    <li class="@(leadStep >= 2 ? "done" : "")"><span class="step-index">2</span> Tu organización</li>
                    <li class="@(leadStep >= 3 ? "done" : "")"><span class="step-index">3</span> Listo</li>
                </ol>

                <div class="checkout-body">
                    <div class="checkout-main">
                        @if (leadStep == 1)
                        {
                            <h3>Cuéntanos cómo contactarte</h3>
                            <EditForm Model="lead" OnValidSubmit="() => leadStep = 2">
                                <DataAnnotationsValidator />
                                <div class="checkout-field">
                                    <label>Nombre de la organización</label>
                                    <InputText @bind-Value="lead.OrganizationName" />
                                </div>
                                <div class="checkout-field">
                                    <label>Nombre de contacto</label>
                                    <InputText @bind-Value="lead.ContactName" />
                                </div>
                                <div class="checkout-field">
                                    <label>Correo electrónico</label>
                                    <InputText @bind-Value="lead.Email" type="email" />
                                </div>
                                <div class="checkout-field">
                                    <label>Teléfono</label>
                                    <InputText @bind-Value="lead.Phone" />
                                </div>
                                <button type="submit" class="btn btn-primary">Continuar</button>
                            </EditForm>
                        }
                        else if (leadStep == 2)
                        {
                            <h3>Ayúdanos a entender tu necesidad</h3>
                            <div class="checkout-field">
                                <label>¿Cuántas iglesias administrarías?</label>
                                <InputNumber @bind-Value="lead.ChurchCount" />
                            </div>
                            <div class="checkout-field">
                                <label>¿Qué funciones te interesan?</label>
                                @foreach (var feature in AvailableLeadFeatures)
                                {
                                    <label class="checkout-plan-option">
                                        <input type="checkbox" checked="@lead.KeyFeatures.Contains(feature)" @onchange="@(e => ToggleLeadFeature(feature, (bool)e.Value!))" />
                                        <span>@feature</span>
                                    </label>
                                }
                            </div>
                            <div class="checkout-field">
                                <label>¿Cuándo te gustaría empezar?</label>
                                <InputSelect @bind-Value="lead.Timeline">
                                    <option value="Inmediato">Inmediato</option>
                                    <option value="1-3 meses">1-3 meses</option>
                                    <option value="3-6 meses">3-6 meses</option>
                                    <option value="Explorando opciones">Explorando opciones</option>
                                </InputSelect>
                            </div>
                            <div class="checkout-field">
                                <label>Comentarios (opcional)</label>
                                <InputTextArea @bind-Value="lead.Comments" />
                            </div>
                            <button type="button" class="btn btn-outline-secondary" @onclick="() => leadStep = 1">Atrás</button>
                            <button type="button" class="btn btn-primary" @onclick="SubmitLeadAsync" disabled="@isSubmittingLead">
                                @(isSubmittingLead ? "Enviando..." : "Enviar")
                            </button>
                            @if (leadError is not null)
                            {
                                <p class="checkout-error">@leadError</p>
                            }
                        }
                        else
                        {
                            <h3>¡Gracias!</h3>
                            <p>
                                Hemos recibido tu información. Nuestro equipo de ventas se pondrá en contacto contigo pronto
                                para platicar sobre el plan Multi-Iglesia.
                            </p>
                            <button type="button" class="btn btn-primary" @onclick="CloseLeadWizard">Cerrar</button>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</main>

@code {
    private enum BillingCycle { Monthly, Annual }

    private BillingCycle billingCycle = BillingCycle.Monthly;
    private PricingPlan? selectedPlan;
    private int checkoutStep = 1;
    private readonly CheckoutAccount account = new();
    private bool isRedirectingToStripe;
    private string? checkoutError;

    private static readonly decimal AnnualDiscount = 1m / 6m;

    private void SetBillingCycle(BillingCycle cycle) => billingCycle = cycle;

    private void OpenCheckout(PricingPlan plan)
    {
        selectedPlan = plan;
        checkoutStep = 1;
    }

    private void CloseCheckout()
    {
        selectedPlan = null;
        checkoutStep = 1;
        checkoutError = null;
    }

    private async Task StartStripeCheckoutAsync()
    {
        if (selectedPlan is null || isRedirectingToStripe)
        {
            return;
        }

        isRedirectingToStripe = true;
        checkoutError = null;

        try
        {
            var baseUri = Navigation.BaseUri.TrimEnd('/');
            var planKey = PlanKeyFor(selectedPlan);
            var request = new CheckoutSessionRequest(
                planKey,
                billingCycle.ToString(),
                account.OrganizationName,
                account.Email,
                account.Phone,
                $"{baseUri}/checkout/success?session_id={{CHECKOUT_SESSION_ID}}",
                $"{baseUri}/?checkout=cancelled");

            var session = await StripeCheckout.CreateCheckoutSessionAsync(request);

            await Signups.CreatePendingSignupAsync(
                new PendingSignup(account.OrganizationName, account.Email, account.Phone, planKey, billingCycle.ToString(), session.SessionId, null),
                account.Password);

            Navigation.NavigateTo(session.Url, forceLoad: true);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Stripe checkout session creation failed for plan {PlanKey}", PlanKeyFor(selectedPlan));
            checkoutError = "No pudimos iniciar el pago. Intenta de nuevo en un momento.";
            isRedirectingToStripe = false;
        }
    }

    private static string PlanKeyFor(PricingPlan plan) => plan.Name switch
    {
        "Básico" => CfsPlans.Basic,
        "Standard" => CfsPlans.Standard,
        "Pro" => CfsPlans.Pro,
        _ => CfsPlans.Basic,
    };

    private static string FormatPrice(PricingPlan? plan, BillingCycle cycle)
    {
        if (plan is null || plan.IsCustomPricing)
        {
            return "Custom";
        }

        var amount = cycle == BillingCycle.Monthly
            ? plan.MonthlyPrice
            : Math.Round(plan.MonthlyPrice * 12 * (1 - AnnualDiscount), 0);

        return $"${amount:0}";
    }

    private static string FormatSavings(PricingPlan? plan)
    {
        if (plan is null || plan.IsCustomPricing)
        {
            return "$0";
        }

        var fullYear = plan.MonthlyPrice * 12;
        var discountedYear = Math.Round(fullYear * (1 - AnnualDiscount), 0);
        return $"${fullYear - discountedYear:0}";
    }

    private static readonly IReadOnlyList<PricingPlan> Plans =
    [
        new(
            "Básico",
            29,
            "Registro financiero simple para iglesias que quieren empezar con orden.",
            [
                "Dashboard financiero",
                "Ingresos y recibos",
                "Depósitos básicos",
                "Reportes básicos",
                "Usuarios limitados"
            ],
            false,
            false),
        new(
            "Standard",
            59,
            "Operación contable completa para la tesorería diaria de una iglesia.",
            [
                "Todo en Básico",
                "Egresos",
                "Cheques tipo voucher",
                "Conciliación bancaria",
                "Reportes por cuenta bancaria",
                "P&L, P&L Detail y Balance Sheet",
                "Más usuarios"
            ],
            true,
            false),
        new(
            "Pro",
            99,
            "IA, auditoría y automatización para iglesias que quieren análisis avanzado.",
            [
                "Todo en Standard",
                "Insights dinámicos",
                "Agente IA financiero",
                "Auditoría avanzada",
                "Automatizaciones",
                "Análisis de tendencias"
            ],
            false,
            false),
        new(
            "Multi-Iglesia",
            0,
            "Administración por organización para concilios, redes o varias sedes.",
            [
                "Todo en Básico y Standard para la iglesia principal",
                "Varias iglesias bajo una organización",
                "Dashboard consolidado",
                "Usuarios por iglesia",
                "Reportes por iglesia y consolidados",
                "Administración central"
            ],
            false,
            true)
    ];

    private sealed record PricingPlan(
        string Name,
        decimal MonthlyPrice,
        string Description,
        IReadOnlyList<string> Features,
        bool Highlight,
        bool IsCustomPricing);

    private sealed class CheckoutAccount
    {
        public string OrganizationName { get; set; } = "";
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
        public string Phone { get; set; } = "";
    }

    private static readonly IReadOnlyList<string> AvailableLeadFeatures =
    [
        "Dashboard consolidado",
        "Reportes por iglesia y consolidados",
        "Administración central",
        "Usuarios por iglesia",
        "Cheques tipo voucher",
        "Conciliación bancaria",
        "Agente IA financiero"
    ];

    private bool showLeadWizard;
    private int leadStep = 1;
    private bool isSubmittingLead;
    private string? leadError;
    private readonly LeadProfile lead = new();

    private void OpenLeadWizard()
    {
        showLeadWizard = true;
        leadStep = 1;
        leadError = null;
    }

    private void CloseLeadWizard()
    {
        showLeadWizard = false;
        leadStep = 1;
        leadError = null;
        lead.Reset();
    }

    private void ToggleLeadFeature(string feature, bool isChecked)
    {
        if (isChecked)
        {
            if (!lead.KeyFeatures.Contains(feature))
            {
                lead.KeyFeatures.Add(feature);
            }
        }
        else
        {
            lead.KeyFeatures.Remove(feature);
        }
    }

    private async Task SubmitLeadAsync()
    {
        if (isSubmittingLead)
        {
            return;
        }

        isSubmittingLead = true;
        leadError = null;

        try
        {
            await SalesLeads.CreateAsync(new SalesLead(
                lead.OrganizationName,
                lead.ContactName,
                lead.Email,
                lead.Phone,
                lead.ChurchCount,
                lead.KeyFeatures,
                lead.Timeline,
                string.IsNullOrWhiteSpace(lead.Comments) ? null : lead.Comments));

            leadStep = 3;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Sales lead submission failed");
            leadError = "No pudimos enviar tu información. Intenta de nuevo en un momento.";
        }
        finally
        {
            isSubmittingLead = false;
        }
    }

    private sealed class LeadProfile
    {
        public string OrganizationName { get; set; } = "";
        public string ContactName { get; set; } = "";
        public string Email { get; set; } = "";
        public string Phone { get; set; } = "";
        public int ChurchCount { get; set; } = 1;
        public List<string> KeyFeatures { get; } = [];
        public string Timeline { get; set; } = "Inmediato";
        public string? Comments { get; set; }

        public void Reset()
        {
            OrganizationName = "";
            ContactName = "";
            Email = "";
            Phone = "";
            ChurchCount = 1;
            KeyFeatures.Clear();
            Timeline = "Inmediato";
            Comments = null;
        }
    }
}
