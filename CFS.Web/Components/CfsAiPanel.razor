@rendermode InteractiveServer
@inject IAiAdvisorService AiAdvisorService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ISubscriptionService SubscriptionService

@if (!isLoadingAccess && hasAccess)
{
    <div class="cfs-ai-host">
        @if (isOpen)
        {
            <section class="cfs-ai-panel" aria-label="Asistente interno de Fidelis">
                <header class="cfs-ai-header">
                    <div>
                        <span>Fidelis AI</span>
                        <strong>Asistente interno</strong>
                    </div>
                    <button type="button" class="icon-button" @onclick="TogglePanel" aria-label="Cerrar asistente">×</button>
                </header>

                <div class="cfs-ai-body">
                    @if (messages.Count == 0)
                    {
                        <div class="cfs-ai-empty">
                            <strong>Pregúntame sobre Fidelis</strong>
                            <p>Saldos en libros, reportes, ingresos, gastos, depósitos, reconciliación o cómo usar el sistema.</p>
                        </div>

                        <div class="cfs-ai-suggestions">
                            @foreach (var suggestion in suggestions)
                            {
                                <button type="button" @onclick="() => UseSuggestion(suggestion)">@suggestion</button>
                            }
                        </div>
                    }
                    else
                    {
                        @foreach (var message in messages)
                        {
                            <article class="cfs-ai-message @message.Role">
                                <span>@(message.Role == "user" ? "Tú" : "Fidelis AI")</span>
                                <p>@message.Text</p>

                                @if (message.Citations.Count > 0)
                                {
                                    <div class="cfs-ai-citations">
                                        @foreach (var citation in message.Citations)
                                        {
                                            <small>@citation.Source · @citation.Label @citation.Reference</small>
                                        }
                                    </div>
                                }
                            </article>
                        }
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(statusMessage))
                {
                    <div class="cfs-ai-status @statusCss">@statusMessage</div>
                }

                <EditForm Model="questionModel" OnValidSubmit="AskAsync" class="cfs-ai-form">
                    <InputTextArea class="form-control" @bind-Value="questionModel.Question" rows="2" placeholder="Pregunta sobre esta iglesia o sobre Fidelis..." />
                    <button class="btn btn-primary" type="submit" disabled="@isAsking">
                        @(isAsking ? "..." : "Enviar")
                    </button>
                </EditForm>
            </section>
        }

        <button type="button" class="cfs-ai-launcher" @onclick="TogglePanel" aria-label="Abrir asistente interno de Fidelis">
            <span aria-hidden="true">✦</span>
            <strong>AI</strong>
        </button>
    </div>
}

@code {
    private readonly List<AiChatMessage> messages = [];
    private readonly string[] suggestions =
    [
        "¿Cómo van las finanzas este mes?",
        "¿Cuál cuenta necesita revisión?",
        "Explícame el Profit and Loss",
        "¿Qué significa saldo en libros Fidelis?"
    ];

    private AiQuestionForm questionModel = new();
    private bool isLoadingAccess = true;
    private bool hasAccess;
    private bool isOpen;
    private bool isAsking;
    private string? statusMessage;
    private string statusCss = "info";
    private int tenantId = 1;
    private int userId = 1;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        hasAccess =
            await SubscriptionService.HasFeatureAsync(authState.User, CfsFeatures.AiAssistantBasic) ||
            await SubscriptionService.HasFeatureAsync(authState.User, CfsFeatures.AiAdvisor);

        tenantId = int.TryParse(authState.User.FindFirst("TenantId")?.Value, out var parsedTenantId) ? parsedTenantId : 1;
        userId = int.TryParse(authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value, out var parsedUserId) ? parsedUserId : 1;
        isLoadingAccess = false;
    }

    private void TogglePanel()
    {
        isOpen = !isOpen;
    }

    private void UseSuggestion(string suggestion)
    {
        questionModel.Question = suggestion;
    }

    private async Task AskAsync()
    {
        if (string.IsNullOrWhiteSpace(questionModel.Question))
        {
            statusMessage = "Escribe una pregunta.";
            statusCss = "warning";
            return;
        }

        isAsking = true;
        statusMessage = null;

        try
        {
            var question = questionModel.Question.Trim();
            messages.Add(new AiChatMessage("user", question, []));

            var answer = await AiAdvisorService.AskAsync(new AiQuestionRequest(
                tenantId,
                userId,
                question,
                new DateTime(DateTime.Today.Year, 1, 1),
                DateTime.Today));

            messages.Add(new AiChatMessage("assistant", answer.Answer, answer.Citations));
            questionModel.Question = string.Empty;
        }
        catch (Exception ex)
        {
            statusMessage = $"No se pudo consultar Fidelis AI: {ex.Message}";
            statusCss = "danger";
        }
        finally
        {
            isAsking = false;
        }
    }

    private sealed class AiQuestionForm
    {
        public string Question { get; set; } = string.Empty;
    }

    private sealed record AiChatMessage(string Role, string Text, IReadOnlyList<AiCitation> Citations);
}
