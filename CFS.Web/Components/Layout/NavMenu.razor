@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ISubscriptionService SubscriptionService
@inject ITenantAccessRepository TenantAccessRepository

<nav class="qb-nav" aria-label="Navegación principal">
    <a class="brand" href="dashboard">
        <img class="brand-logo" src="images/fidelis-logo.png" alt="Fidelis Financial Management" />
        <span>Fidelis Financial Management</span>
    </a>

    @if (accessibleTenants.Count > 1)
    {
        <details class="tenant-switcher">
            <summary class="tenant-switcher-current">@CurrentTenantName</summary>
            <div class="tenant-switcher-options">
                @foreach (var tenant in accessibleTenants)
                {
                    <form method="post" action="@($"/switch-tenant/{tenant.TenantId}")">
                        <AntiforgeryToken />
                        <button type="submit" class="tenant-switcher-option" disabled="@(tenant.TenantId == activeTenantId)">
                            @tenant.TenantName
                        </button>
                    </form>
                }
            </div>
        </details>
    }

    <a class="create-button" href="ingresos">
        <span aria-hidden="true">+</span>
        Nuevo ingreso
    </a>

    <div class="nav-section">
        @if (HasFeature(CfsFeatures.Dashboard))
        {
            <NavLink class="nav-link" href="dashboard">
                <span class="nav-icon" aria-hidden="true">⌂</span>
                Dashboard
            </NavLink>
        }
        @if (HasFeature(CfsFeatures.Income))
        {
            <NavLink class="nav-link" href="ingresos">
                <span class="nav-icon" aria-hidden="true">$</span>
                Ingresos
            </NavLink>
        }
        @if (HasFeature(CfsFeatures.Expenses))
        {
            <NavLink class="nav-link" href="egresos">
                <span class="nav-icon" aria-hidden="true">−</span>
                Egresos
            </NavLink>
        }
        @if (HasFeature(CfsFeatures.Checks))
        {
            <NavLink class="nav-link" href="cheques">
                <span class="nav-icon" aria-hidden="true">▤</span>
                Cheques
            </NavLink>
            <NavLink class="nav-link" href="configuracion/cheques">
                <span class="nav-icon" aria-hidden="true">⚙</span>
                Formato de cheques
            </NavLink>
        }
        @if (HasFeature(CfsFeatures.Deposits))
        {
            <NavLink class="nav-link" href="depositos">
                <span class="nav-icon" aria-hidden="true">⇣</span>
                Depósitos
            </NavLink>
        }
        @if (HasFeature(CfsFeatures.Reconciliation))
        {
            <NavLink class="nav-link" href="conciliacion">
                <span class="nav-icon" aria-hidden="true">✓</span>
                Conciliación
            </NavLink>
        }
        @if (HasFeature(CfsFeatures.ReportsBasic))
        {
            <NavLink class="nav-link" href="reportes">
                <span class="nav-icon" aria-hidden="true">▥</span>
                Reportes
            </NavLink>
        }
        @if (subscription is not null && !subscription.IsFounderAccount)
        {
            <NavLink class="nav-link" href="configuracion/plan">
                <span class="nav-icon" aria-hidden="true">★</span>
                Plan y Add-ons
            </NavLink>
        }
        @if (isFounderAdmin)
        {
            <NavLink class="nav-link" href="admin/signups">
                <span class="nav-icon" aria-hidden="true">⚑</span>
                Signups
            </NavLink>
        }
    </div>

    <div class="nav-footer">
        <a class="nav-footer-link" href="mailto:soporte@fidelisfm.com">
            <span class="nav-icon" aria-hidden="true">?</span>
            Soporte
        </a>
        <span class="nav-footer-version">Fidelis Financial Management</span>
    </div>
</nav>

@code {
    private TenantSubscription? subscription;
    private bool isFounderAdmin;
    private IReadOnlyList<TenantAccessOption> accessibleTenants = [];
    private int activeTenantId;
    private string CurrentTenantName =>
        accessibleTenants.FirstOrDefault(t => t.TenantId == activeTenantId)?.TenantName ?? string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        subscription = await SubscriptionService.GetCurrentAsync(authState.User);
        isFounderAdmin = authState.User.FindFirst("TenantId")?.Value == "1" && authState.User.IsInRole("Administrador");

        activeTenantId = int.TryParse(authState.User.FindFirst("TenantId")?.Value, out var tenantId) ? tenantId : 1;
        var userId = int.TryParse(authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value, out var id) ? id : 0;
        try
        {
            accessibleTenants = await TenantAccessRepository.GetAccessibleTenantsAsync(userId);
        }
        catch (Exception)
        {
            // Keeps the shared layout (and every page that uses it) usable even if the
            // UserTenantAccess/TenantNetworks tables aren't provisioned yet in this environment.
            accessibleTenants = [];
        }
    }

    private bool HasFeature(string featureKey) =>
        subscription?.HasFeature(featureKey) ?? true;
}
